# -------------------------------------------------------------
# Rebuild Dataset
# -------------------------------------------------------------

TARGET = "CHE_Risk"

# Columns that leak information into the target
LEAKAGE_COLUMNS = [
    "Health_Exp_Income_Ratio",
    "High_Health_Spending"
]

ID_COLUMNS = [
    "Household_ID"
]

DROP_COLUMNS = LEAKAGE_COLUMNS + ID_COLUMNS

X = df.drop(columns=[TARGET] + DROP_COLUMNS)

y = df[TARGET]

print("\nRemaining Features")

print(X.columns.tolist())

print("\nTotal Features:", len(X.columns))

###############################################################
# Detect Feature Types Again
###############################################################

categorical_features = X.select_dtypes(
    include=["object", "category"]
).columns.tolist()

numerical_features = X.select_dtypes(
    include=["number"]
).columns.tolist()

print("\nCategorical Features")

print(categorical_features)

print("\nNumerical Features")

print(numerical_features)

###############################################################
# Build New Preprocessing Pipeline
###############################################################

numeric_transformer = Pipeline(
    steps=[
        (
            "imputer",
            SimpleImputer(strategy="median")
        ),
        (
            "scaler",
            StandardScaler()
        )
    ]
)

categorical_transformer = Pipeline(
    steps=[
        (
            "imputer",
            SimpleImputer(strategy="most_frequent")
        ),
        (
            "encoder",
            OneHotEncoder(
                handle_unknown="ignore"
            )
        )
    ]
)

preprocessor = ColumnTransformer(
    transformers=[
        (
            "num",
            numeric_transformer,
            numerical_features
        ),
        (
            "cat",
            categorical_transformer,
            categorical_features
        )
    ]
)

###############################################################
# New Train/Test Split
###############################################################

X_train, X_test, y_train, y_test = train_test_split(
    X,
    y,
    stratify=y,
    test_size=0.20,
    random_state=42
)

print("\nTraining Shape")

print(X_train.shape)

print("\nTesting Shape")

print(X_test.shape)

